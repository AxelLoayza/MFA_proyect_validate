LISTEN_URL=http://0.0.0.0:4000
BACKEND_GOOGLE_REDIRECT=https://your-domain.example.com/api/auth/callback/google
NODE_ENV=development

# CORS origins: comma-separated list. Use '*' to allow all origins.
# For LAN testing, replace YOUR_PC_LAN_IP with the machine IP.
CORS_ORIGINS=http://localhost:59671,http://localhost:60407,http://localhost:8080,http://YOUR_PC_LAN_IP:8080,http://YOUR_PC_LAN_IP:*

DB_HOST=localhost
DB_PORT=5432
DB_USER=azure_local
DB_PASSWORD=your_local_db_password
DB_NAME=azure_emulator

JWT_ALGO=RS256
JWT_ISSUER=LocalAzure
TEMP_TOKEN_TTL_SECONDS=900
FINAL_TOKEN_TTL_SECONDS=3600
JWT_EXPIRES_IN=15m

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

CLOUD_JWKS_URL=http://localhost:9000/.well-known/jwks.json
CLOUD_ISSUER=cloud-scorer.local
CLOUD_AUDIENCE=local-azure-emulator

# SDK / ApiContainer for Google verification
SDK_URL=http://localhost:9001
SDK_API_KEY=sdk_default_key
SDK_SECRET=sdk_default_secret

# Public gateway token bridge
CLOUD_PUBLIC_BACKEND_URL=http://localhost:4003

# MongoDB Cloud Configuration
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.niw3emu.mongodb.net/mfa_biometric?retryWrites=true&w=majority&appName=Cluster0
SECURITY_KEY=replace_with_a_long_random_secret
