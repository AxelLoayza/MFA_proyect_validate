PORT=4000
NODE_ENV=development
 
# CORS origins: comma-separated list. Use '*' to allow all origins.
# To allow any localhost port use: http://localhost:*
CORS_ORIGINS=http://localhost:59671,http://localhost:60407

DB_HOST=localhost
DB_PORT=5432
DB_USER=azure_local
DB_PASSWORD=12345
DB_NAME=azure_emulator

JWT_ALGO="tipo_alg"
