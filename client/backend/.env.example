PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS origins for the Flutter web client.
# Use CORS=* only for local development.
CORS=http://localhost:59671,http://localhost:8080,http://localhost:61992
FRONTEND_URL=http://localhost:59671

# PostgreSQL used by client/backend migrations and login session storage.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=mfa_db

# JWT signing keys generated in client/backend/src/keys.
JWT_ALGO=RS256
JWT_ISSUER=LocalAzure
JWT_PRIVATE_KEY_PATH=src/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=src/keys/jwt_public.pem
TEMP_TOKEN_TTL_SECONDS=120
FINAL_TOKEN_TTL_SECONDS=900
JWT_EXPIRES_IN=15m

# Optional development shortcuts. Keep false outside local tests.
AUTH_DEV_BYPASS=false
BYPASS_CLOUD_ASSERTION=false

# Rate limiting.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Biometric scoring.
BIOMETRIC_SCORE_THRESHOLD=0.85
BIOMETRIC_SECRET_KEY=replace_with_64_hex_characters

# SDK / apiContainer integration.
SDK_URL=http://localhost:9001
API_CONTAINER_URL=http://localhost:9001
SDK_API_KEY=sdk_default_key
SDK_SECRET=sdk_default_secret
ML_SERVICE_USERNAME=bmfa_user
ML_SERVICE_PASSWORD=your_secure_password_here

# Public gateway used for enrollment and current-user checks.
CLOUD_PUBLIC_BACKEND_URL=http://localhost:4003

# Google OAuth redirect flow, if you use the backend callback flow.
WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
WEB_CLIENT_SECRET=your-google-client-secret
BACKEND_GOOGLE_REDIRECT=http://localhost:4000/api/auth/callback/google

# MongoDB used by cloud-compatible user/profile operations.
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/mfa_biometric?retryWrites=true&w=majority
MONGO_DB_NAME=mfa_biometric
SECURITY_KEY=replace_with_a_strong_32_byte_secret

# Legacy cloud scorer settings.
CLOUD_JWKS_URL=http://localhost:9000/.well-known/jwks.json
CLOUD_ISSUER=cloud-scorer.local
CLOUD_AUDIENCE=local-azure-emulator
