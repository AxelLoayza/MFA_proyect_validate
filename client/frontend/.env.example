GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Web debug URL used by flutter run -d chrome/edge
WEB_APP_URL=http://localhost:8080

# Android device URL when testing over LAN
ANDROID_APP_URL=http://YOUR_PC_LAN_IP:8080

# Client backend entrypoint used by Flutter
BACKEND_URL=http://YOUR_PC_LAN_IP:4000

# Public gateway used by bootstrap/session checks
PUBLIC_BACKEND_URL=http://YOUR_PC_LAN_IP:4003

# ApiContainer / SDK bridge
CLOUD_SERVICE_URL=http://localhost:9001
SDK_URL=http://localhost:9001