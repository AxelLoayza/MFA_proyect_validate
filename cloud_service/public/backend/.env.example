# ============================================================================
# Cloud Service Public Backend / Public Gateway
# Copy this file to .env and replace placeholders with your own credentials.
# ============================================================================

PORT=4003
NODE_ENV=development
APP_NAME=ARC Secure Cloud

# MongoDB. Use your own Atlas/local credentials when cloning elsewhere.
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/mfa_biometric?retryWrites=true&w=majority
MONGO_DB_NAME=mfa_biometric

# Google OAuth. The same client id is used by Flutter and the admin frontend.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_ALLOWED_CLIENT_IDS=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs

# JWT signing. These paths are relative to cloud_service/public/backend.
JWT_ALGO=RS256
JWT_ISSUER=LocalAzure
JWT_PUBLIC_KEY_PATH=../../../client/backend/src/keys/jwt_public.pem
JWT_PRIVATE_KEY_PATH=../../../client/backend/src/keys/jwt_private.pem
JWT_EXPIRATION_SECONDS=3600

# Biometric encryption. SECURITY_KEY can be a strong passphrase; BIOMETRIC_SECRET_KEY
# can be a 64-character hex key if you prefer explicit AES key material.
SECURITY_KEY=replace_with_a_strong_32_byte_secret
BIOMETRIC_SECRET_KEY=replace_with_64_hex_characters

# SDK / apiContainer.
SDK_URL=http://localhost:9001
SDK_API_KEY=sdk_default_key
SDK_SECRET=sdk_default_secret

# Private ML service used by /auth/step-up.
PRIVATE_LSTM_URL=http://localhost:8000
ML_SERVICE_USERNAME=bmfa_user
ML_SERVICE_PASSWORD=your_secure_password_here

# Mail for tenant invitations. Use your own SMTP/app password.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-app-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=your-email@example.com
MAIL_FROM_NAME=ARC Secure Cloud
INVITE_EXPIRATION_DAYS=1
