# MongoDB
# Use the replica-set URI if your environment cannot resolve mongodb+srv DNS records
MONGO_URI=mongodb://user:password@host1:27017,host2:27017,host3:27017/mfa_biometric?replicaSet=your-replica-set&authSource=admin&retryWrites=true&w=majority&tls=true
MONGO_DB_NAME=mfa_biometric

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Google OAuth redirect URI used by the backend callback flow
GOOGLE_REDIRECT_URI=https://your-domain.example.com/api/auth/callback/google
# Optional: override JWKS URI (defaults to Google's JWKS)
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs

# JWT signing (use the RSA pair generated in backend/keys)
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_EXPIRATION_SECONDS=3600

# Biometric encryption secret used by src/utils/crypto.js
BIOMETRIC_SECRET_KEY=<hex-32-bytes>

# SDK / apiContainer used by /enroll and Google flows
SDK_URL=http://localhost:9001

# Private LSTM validation service used by /step-up
PRIVATE_LSTM_URL=http://localhost:9000
ML_SERVICE_USERNAME=bmfa_user
ML_SERVICE_PASSWORD=your_secure_password_here

# App bind URL
LISTEN_URL=http://0.0.0.0:4003
