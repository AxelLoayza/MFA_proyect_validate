# MongoDB
# Use the replica-set URI if your environment cannot resolve mongodb+srv DNS records
MONGO_URI=mongodb://user:password@host1:27017,host2:27017,host3:27017/mfa_biometric?replicaSet=your-replica-set&authSource=admin&retryWrites=true&w=majority&tls=true
MONGO_DB_NAME=mfa_biometric

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional: override JWKS URI (defaults to Google's JWKS)
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs

# JWT signing (use the RSA pair generated in client/backend/src/keys)
JWT_PUBLIC_KEY_PATH=../../../client/backend/src/keys/jwt_public.pem
JWT_PRIVATE_KEY_PATH=../../../client/backend/src/keys/jwt_private.pem
JWT_EXPIRATION_SECONDS=3600

# Private LSTM validation service used by /step-up
PRIVATE_LSTM_URL=http://localhost:9001
ML_SERVICE_USERNAME=bmfa_user
ML_SERVICE_PASSWORD=your_secure_password_here

# App
PORT=4000
