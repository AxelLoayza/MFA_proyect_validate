# ============================================================================
# Cloud Service Private - Biometric ML service
# Copy this file to .env and replace placeholders with your own credentials.
# ============================================================================

API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=false

# Basic Auth. These values must match:
# - apiContainer CLOUD_PROVIDER_USERNAME / CLOUD_PROVIDER_PASSWORD
# - public backend ML_SERVICE_USERNAME / ML_SERVICE_PASSWORD
ML_SERVICE_USERNAME=bmfa_user
ML_SERVICE_PASSWORD=your_secure_password_here

# Rate limiting and request size.
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_SIZE=204800

# Stroke point validation.
MIN_STROKE_POINTS=100
MAX_STROKE_POINTS=1200
MODEL_INPUT_POINTS=100

# TLS/HTTPS. Use false for the local initializer; use true with real certs in production.
TLS_ENABLED=false
TLS_CERT_FILE=./certs/server.crt
TLS_KEY_FILE=./certs/server.key
VERIFY_CLIENT_CERTIFICATES=false

# ML model configuration. The app prefers the bundled local model when present.
MODEL_PATH=./src/app/Entrenamineto_LSTM/embedding_network_mini.h5
MODEL_VERSION=lstm_v1
PREPROCESSING_PROFILE=advanced8
CONFIDENCE_THRESHOLD=0.7
MODEL_SEQUENCE_LENGTH=100
MODEL_FEATURES_PER_POINT=4

# MongoDB for biometric profiles/logs. Use your own Atlas/local credentials.
MONGO_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/mfa_biometric?retryWrites=true&w=majority
MONGO_DB_NAME=mfa_biometric
MONGO_COLLECTION_PROFILES=biometricprofile
MONGO_COLLECTION_LOGS=audit_logs

# Logging and CORS.
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
