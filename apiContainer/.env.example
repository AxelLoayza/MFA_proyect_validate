# ============================================================================
# apiContainer - Biometric normalization SDK
# Copy this file to .env and replace placeholders with your own credentials.
# ============================================================================

# API server. The initializer starts this service on port 9001.
API_HOST=0.0.0.0
API_PORT=9001
ENVIRONMENT=development
DEBUG=true

# JWT validation. Use the same public key pair generated in client/backend/src/keys.
JWT_PUBLIC_KEY_PATH=../client/backend/src/keys/jwt_public.pem
JWT_ISSUER=LocalAzure
JWT_AUDIENCE=bmfa-processor

# Signature provider credentials.
SIGNATURE_PROVIDER_USERNAME=bmfa_validator
SIGNATURE_PROVIDER_PASSWORD=secure_password_change_me

# Private ML service used for enrollment normalization and validation.
CLOUD_PROVIDER_ENDPOINT=http://localhost:8000/api/biometric
CLOUD_PROVIDER_USERNAME=bmfa_user
CLOUD_PROVIDER_PASSWORD=your_secure_password_here
CLOUD_PROVIDER_TIMEOUT=30
CLOUD_PROVIDER_VERIFY_SSL=false

# Public cloud gateway used for Google verification and ARC step-up.
CLOUD_SERVICE_URL=http://localhost:4003
PUBLIC_GATEWAY_STEP_UP_ENDPOINT=http://localhost:4003/auth/step-up
PUBLIC_GATEWAY_TIMEOUT=30

# SDK shared credentials. Keep these aligned with client/backend and public backend.
SDK_API_KEY=sdk_default_key
SDK_SECRET=sdk_default_secret

# Biometric normalization.
MIN_STROKE_POINTS=100
MAX_STROKE_POINTS=1200
PADDING_STRATEGY=linear_interpolation
NORMALIZATION_PROFILE=repo_compat

# Rate limiting and request size.
RATE_LIMIT_REQUESTS=8
MAX_REQUEST_SIZE=102400

# Logging.
LOG_LEVEL=INFO
